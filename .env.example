# =============================================================================
# Tempo Platform - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.

# --- Database ---
DATABASE_URL=

# --- Auth ---
JWT_SECRET=

# --- Sentry Error Monitoring ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Stripe Billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Email ---
RESEND_API_KEY=
SENDGRID_API_KEY=

# --- Storage (S3) ---
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=

# --- Vercel (auto-set on Vercel) ---
NEXT_PUBLIC_VERCEL_ENV=
